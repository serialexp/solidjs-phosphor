{
  "name": "solidjs-phosphor",
  "version": "3.0.0",
  "description": "Phosphor Icons for SolidJS — auto-generated from phosphor-icons/core",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "solid": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "solid-js": ">=1.0.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260401.1",
    "solid-js": "^1.9.12",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-solid": "^2.11.11"
  },
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "build": "vite build && tsc --emitDeclarationOnly",
    "check": "tsgo --noEmit",
    "prepublishOnly": "pnpm run generate && pnpm run check && pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aeolun/phosphor-solid"
  },
  "keywords": [
    "phosphor",
    "icons",
    "solidjs",
    "solid",
    "components"
  ]
}
