{
  "name": "solidjs-phosphor",
  "version": "2.1.1",
  "description": "Phosphor Icons for SolidJS — auto-generated from phosphor-icons/core",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "solid": "./src/index.tsx",
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "solid-js": ">=1.0.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260401.1",
    "solid-js": "^1.9.12",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "check": "tsgo --noEmit",
    "prepublishOnly": "npm run generate && npm run check"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aeolun/phosphor-solid"
  },
  "keywords": [
    "phosphor",
    "icons",
    "solidjs",
    "solid",
    "components"
  ]
